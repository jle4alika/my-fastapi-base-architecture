# Скопируйте в backend/.env и подправьте значения.
# Локальный запуск: cd backend && USE_SQLITE=true uvicorn backend.api.app:app

# --- API ---
API_PORT=8000
USE_SQLITE=true

# JWT / fastapi-users
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_LONG_SECRET
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# --- PostgreSQL (USE_SQLITE=false) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=fastapi_architecture
USE_PGBOUNCER=false

# --- Миграции Alembic (make -C backend migrate) ---
# DB_MIGRATE_ON_STARTUP=false
# DB_CREATE_ALL_ON_STARTUP=false

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- RabbitMQ ---
RMQ_HOST=localhost
RMQ_PORT=5672
RMQ_LOGIN=guest
RMQ_PASS=guest

# --- Медиа ---
MEDIA_UPLOAD_DIR=uploads
MEDIA_MAX_BYTES=20971520
