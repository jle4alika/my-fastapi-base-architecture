# Database — приложения ходят через PgBouncer (локально порт 6432)
DB_HOST=localhost
DB_PORT=6432
DB_USER=postgres
DB_PASS=mysecretpassword
DB_NAME=gloomth_messanger
USE_SQLITE=false
USE_PGBOUNCER=true

# PgBouncer
PB_MAX_CLIENTS=100
PB_DEFAULT_POOL_SIZE=10
PB_POOL_MODE=transaction
PGBOUNCER_PORT=6432

# Postgres напрямую (миграции)
POSTGRES_PUBLISHED_PORT=5433

# Security
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_LONG_SECRET

# RabbitMQ
RMQ_HOST=localhost
RMQ_PORT=5672
RMQ_MANAGEMENT_PORT=15672
RMQ_LOGIN=guest
RMQ_PASS=guest

# Redis
REDIS_PORT=6379
REDIS_GUI_PORT=5540
